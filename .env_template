# === LLM API Keys ===
OPENAI_API_KEY=sk-xxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxx
QWEN_API_KEY=sk-xxxxxxx
GEMINI_API_KEY=sk-xxxxxxx

# === Model Selection ===
# Options: gpt-4o (default) | deepseek | qwen | gemini
MODEL_TYPE=qwen

# === Solver Paths ===
CVC5_BINARY=./cvc/cvc5-Linux-x86_64-static/bin/cvc5
CVC4_BINARY=./cvc/cvc4_binary/cvc4-1.6-x86_64-linux-opt
VAMPIRE_BINARY=./vampire/vampire

# === Network Proxy (optional) ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# === Runtime Parameters (optional, defaults shown) ===
# MAX_ATTEMPTS_PER_PROMPT=3
# DEFAULT_CVC_TIMEOUT=60
# RETRY_CVC_TIMEOUT=100
# COMBINED_CVC_TIMEOUT=60
# MAX_RECURSION_DEPTH=3
# TASK_TIMEOUT=1200
# MAX_PARALLEL_TASKS=20
